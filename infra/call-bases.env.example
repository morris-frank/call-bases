# Environment for the call-bases systemd service. Copy to /opt/call-bases/call-bases.env.
#
# Pacing: set START_EPOCH plus EXACTLY ONE of RATE or RUNTIME_SECONDS.
# For a 3.2 Gb genome:  ~101 b/s  -> ~1 year   |   ~1235 b/s -> ~30 days.

CALLBASES_ARTIFACTS_DIR=/opt/call-bases/artifacts
CALLBASES_WEB_DIR=/opt/call-bases/web
CALLBASES_LISTEN=127.0.0.1:8080

CALLBASES_START_EPOCH=2026-07-01T00:00:00Z
# CALLBASES_RATE=101
CALLBASES_RUNTIME_SECONDS=31536000

CALLBASES_TAIL=4096
CALLBASES_TICK_MS=250
# CALLBASES_PILEUP=true   # auto-detected from artifacts if unset
